generator client {
  provider = "prisma-client"
  output   = "generated"
}

datasource db {
  provider = "postgresql"
}


/////**** ENUMS ****/////

enum Mode {
  OPENING
  LIVE
}

enum Role {
  ADMIN
  STAFF
}

enum Account {
  CASH
  BANK
  INVENTORY
  COGS
  REVENUE
  EXPENSE
  LIABILITIES
  OWNER_CAPITAL
  OWNER_DRAWINGS
  FIXED_ASSETS
  INTER_BRANCH
}

enum AlertType {
  LOW_STOCK
  SUBSCRIPTION
  LIABILITY_DUE
  CASH_VARIANCE
  SYSTEM
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum BusinessStatus {
  ONBOARDING
  ACTIVE
  SUSPENDED
}
enum SyncEventStatus {
  PENDING
  SYNCED
  FAILED
}

///**** MODELS****///


model Business {
  id          String    @id 
  name        String
  address     String?
  isOnboarding  Boolean   @default(true)
  onboardingCompleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  activatedAt DateTime?
  status      BusinessStatus    @default(ONBOARDING)

  users       User[]
  branches    Branch[]
  subscriptions   BusinessSubscription[]
  alerts      Alert[]

}
model Branch {
  id      String    @id    
  businessId    String  
  name          String
  address       String?   
  phone         String?
  isActive      Boolean       @default(true)
  isDefault     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  business      Business      @relation(fields: [businessId], references: [id])

  users         User[]
  alerts        Alert[]
  snapshots     Snapshot[]
}

model User {
  id          String    @id   @default(uuid())
  name        String
  email       String    @unique
  password    String
  role        Role      @default(STAFF)

  isActive    Boolean   @default(true)
  onboardingCompleted   Boolean     @default(false)
  branchId    String?
  businessId  String?
  createdAt   DateTime  @default(now())

  business    Business? @relation(fields: [businessId], references: [id])
  branch      Branch?    @relation(fields: [branchId], references: [id])

  passwordResetTokens passwordResetToken[]



  @@index([businessId])
}


model passwordResetToken {
  id          String    @id 
  userId      String
  token       String    @unique
  expiresAt   DateTime
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model SubscriptionPlan {
  id    String  @id   
  name  String
  price   Decimal
  billingCycle  String

  maxUsers    Int
  maxBranch   Int
  maxProduct  Int
  maxStaff    Int
  
  features    Json
  createdAt   DateTime    @default(now())

  subscription    BusinessSubscription[]
}

model BusinessSubscription {
  id              String    @id     
  businessId      String  @unique   
  subscriptionId  String
  startedAt       DateTime        @default(now())
  expiresAt       DateTime
  trialEndDate    DateTime?
  status          String          @default("ACTIVE")

  business        Business @relation(fields: [businessId], references: [id])
  subscription    SubscriptionPlan @relation(fields: [subscriptionId], references: [id])
}
model ProcessedSyncEvent {
  id          String   @id
  eventType   String
  businessId  String?
  branchId    String?
  userId      String?
  version     Int
  status      SyncEventStatus
  processedAt DateTime @default(now())
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([branchId])
  @@unique([id, status])
}

model Event {
  id         String   @id
  type       String
  payload    Json

  businessId String?
  branchId   String?
  
  mode       Mode
  scope      String

  createdAt  DateTime
  logicClock Int
  version    Int      @default(1)

  deviceId   String
  userId     String?

  status     SyncEventStatus
  synced     Boolean 

  ledgerEntries LedgerEntry[]

  @@index([scope, businessId, branchId, version])
  @@index([deviceId, logicClock])

  @@unique([scope, businessId, branchId, version])
}


model LedgerEntry {
  id          String   @id @default(uuid())
  businessId  String
  branchId    String
  eventId     String

  account     Account
  amount      Decimal

  index       Int       // 👈 ensures deterministic ordering
  createdAt   DateTime  @default(now())

  event       Event     @relation(fields: [eventId], references: [id])

  @@unique([eventId, index]) // 👈 idempotency
  @@index([businessId, branchId])
}

model Snapshot {
  id         String   @id @default(uuid())
  branchId   String
  account    String
  balance    Decimal

  lastVersion Int
  updatedAt   DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, account])
}

model Alert {
  id            String   @id 
  businessId    String
  branchId      String   // null = global alert
  type          AlertType
  severity      AlertSeverity
  title         String
  message       String
  isResolved    Boolean   @default(false)
  isRead        Boolean   @default(false)
  metadata      Json?
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  business Business @relation(fields: [businessId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])

  @@index([branchId, isResolved])
  @@index([businessId, isResolved])
  @@index([type])
  @@unique([branchId, type, isResolved, metadata])
}
