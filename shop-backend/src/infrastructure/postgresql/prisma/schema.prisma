generator client {
  provider = "prisma-client"
  output   = "generated"
}

datasource db {
  provider = "postgresql"
}


/////**** ENUMS ****/////

enum ProductType { 
  ACCESSORY
  PHONE
  SERVICE
  OTHER
}
enum ProductStockMode {
  OPENING
  LIVE
}

enum StockMovementType {
  OPENING
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  TRANSFER
  POS
}

enum CashFlowType {
OPENING
OWNER_CAPITAL
OWNER_WITHDRAWAL
SALE_INCOME
PURCHASE_EXPENSE
ASSET_PURCHASE
ASSET_DISPOSAL
LIABILITY_PAYMENT
EXPENSE
REFUND
}

enum CashFlowDirection {
  IN
  OUT
}
enum LiabilityType {
  LOAN
  CREDIT
  SALARY_ADVANCE
  }

  
enum Role {
  ADMIN
  STAFF
}


enum SaleStatus {
  COMPLETED
  REFUNDED
  VOIDED
}

enum ExpenseStatus {
  APPROVED
  PENDING
  CANCELLED
}

enum InventoryTransactionType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum CapitalTransactionType {
  INJECTION
  WITHDRAWAL
}
enum LiabilityStatus {
  ACTIVE 
  SETTLED
}

enum AlertType {
  LOW_STOCK
  SUBSCRIPTION
  LIABILITY_DUE
  CASH_VARIANCE
  SYSTEM
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}
enum AssetType {
  OPENING
  PURCHASE
  SALE
}
enum BusinessStatus {
  ONBOARDING
  ACTIVE
  SUSPENDED
}

///**** MODELS****///


model Business {
  id          String    @id 
  name        String
  address     String?
  onboardingStep  Int   @default(1)
  isOnboarding  Boolean   @default(true)
  onboardingCompleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  activatedAt DateTime?
  status      BusinessStatus    @default(ONBOARDING)

  branch     Branch[]
  users      User[]
  subscriptions   BusinessSubscription[]
  categories Category[]
  brands      Brand[]
  products   Product[]
  stockMovement     StockMovement[]
  sales      Sale[]
  cashFlows  CashFlow[] 
  liabilities Liability[]
  ledger      LedgerAccount[]
  ledgerEntry LedgerEntry[]
  loan        Loan[] 
  employees    Employee[]
  assets      Asset[]
  expenses    Expense[]
  expenseCategories ExpenseCategory[]
  alerts      Alert[]

}
model Branch {
  id      String    @id    
  businessId    String  
  name          String
  address       String?   
  phone         String?
  isActive      Boolean       @default(true)
  isDefault     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  business      Business      @relation(fields: [businessId], references: [id])

  users         User[]
  products      Product[]
  category      Category[]
  brand         Brand[]
  sales         Sale[]
  stockMovement StockMovement[]
  cashflows     CashFlow[]
  assets        Asset[]
  liabilities   Liability[]
  expenses      Expense[]
  alerts        Alert[]
}

model User {
  id          String    @id   @default(uuid())
  name        String
  email       String    @unique
  password    String
  isActive    Boolean   @default(true)
  onboardingCompleted   Boolean     @default(false)
  role        Role      @default(STAFF)
  branchId    String?
  businessId  String?
  createdAt   DateTime  @default(now())

  business    Business? @relation(fields: [businessId], references: [id])
  branch      Branch?    @relation(fields: [branchId], references: [id])
  passwordResetTokens passwordResetToken[]


  @@index([businessId])
}


model passwordResetToken {
  id          String    @id 
  userId      String
  token       String    @unique
  expiresAt   DateTime
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model SubscriptionPlan {
  id    String  @id   
  name  String
  price   Decimal
  billingCycle  String

  maxUsers    Int
  maxBranch   Int
  maxProduct  Int
  maxStaff    Int
  
  features    Json
  createdAt   DateTime    @default(now())

  subscription    BusinessSubscription[]
}

model BusinessSubscription {
  id              String    @id     
  businessId      String  @unique   
  subscriptionId  String
  startedAt       DateTime        @default(now())
  expiresAt       DateTime
  trialEndDate    DateTime?
  status          String          @default("ACTIVE")

  business        Business @relation(fields: [businessId], references: [id])
  subscription    SubscriptionPlan @relation(fields: [subscriptionId], references: [id])
}
model LedgerAccount {
  id          String   @id
  businessId  String
  name        String
  type        String

  entries     LedgerEntry[]

  business    Business @relation(fields: [businessId], references: [id])
}

model LedgerEntry {
  id          String   @id 
  accountId   String
  businessId  String
  amount      Decimal
  type        String
  referenceId String?
  createdAt   DateTime @default(now())

  account     LedgerAccount @relation(fields: [accountId], references: [id])
  business    Business @relation(fields: [businessId], references: [id])
}

model Category {
  id          String    @id 
  name        String
  businessId  String
  branchId    String
  imageUrl    String?
  createdAt   DateTime  @default(now())
  business    Business  @relation(fields: [businessId], references: [id])
  branch      Branch    @relation(fields: [branchId], references: [id])

  product     Product[]
  brands      Brand[]

  @@unique([name, businessId, branchId])
}

model Brand {
  id          String    @id 
  name        String
  businessId  String
  categoryId  String
  branchId     String
  business    Business  @relation(fields: [businessId], references: [id])
  branch      Branch    @relation(fields: [branchId], references: [id])
  category    Category  @relation(fields: [categoryId], references: [id])
  products    Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, categoryId, branchId])
}

model Product {
  id          String    @id 
  businessId  String
  branchId    String
  categoryId String
  brandId     String
  name        String
  type        ProductType
  stockMode   ProductStockMode  @default(OPENING)
  model       String?
  costPrice   Decimal
  sellingPrice Decimal
  quantity    Int       @default(0)
  imageUrl    String?
  sku         String?
  reorderLevel  Int?
  isDeleted    Boolean    @default(false)

  //Accessories only 
  imei        String?   @unique
  condition    String?
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  business    Business  @relation(fields: [businessId], references: [id])
  branch      Branch    @relation(fields: [branchId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])
  brand       Brand    @relation(fields: [brandId], references: [id])

  stockMoves StockMovement[]  
  saleItem   SaleItem[]

  @@index([businessId])
  @@index([type])
}
model StockMovement {
  id          String           @id 
  businessId  String
  branchId    String
  productId   String
  type        StockMovementType
  quantity    Int
  remainingQty  Int           @default(0)
  costPrice   Decimal?
  sellingPrice Decimal?
  isOpening   Boolean             @default(true)
  date        DateTime          @default(now())
  createdAt   DateTime          @default(now())

  business    Business          @relation(fields: [businessId], references: [id])
  branch      Branch            @relation(fields: [branchId], references: [id])
  product     Product           @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([createdAt])
}


model Sale {
  id            String        @id 
  businessId    String
  branchId      String?
  discount      Decimal?
  totalAmount   Decimal
  createdAt     DateTime      @default(now())
  status        SaleStatus    @default(COMPLETED)
  refundedAt     DateTime?
  refundReason   String?
  taxAmount      Decimal?


  business      Business      @relation(fields: [businessId], references: [id])
  branch        Branch?        @relation(fields: [branchId], references: [id])
  items         SaleItem[]
  payments     Payment[]

  @@index([businessId])
  @@index([createdAt])
}

model SaleItem {
  id          String    @id 
  saleId      String
  productId   String
  quantity    Int
  costPrice   Decimal?
  unitPrice   Decimal
  totalPrice  Decimal

  sale        Sale      @relation(fields: [saleId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id          String        @id 
  saleId      String
  amount      Decimal
  method      PaymentMethod
  date        DateTime      @default(now())
  reference   String?

  sale        Sale          @relation(fields: [saleId], references: [id])

  @@index([saleId])
  @@index([date])
}

model CashFlow {
  id          String        @id 
  businessId  String
  branchId    String
  type        CashFlowType
  amount      Decimal
  direction   CashFlowDirection
  balanceAfter  Decimal?
  source      String?
  description String?
  isOpening   Boolean      @default(false)
  isLocked    Boolean      @default(false)
  createdAt   DateTime      @default(now())

  business    Business      @relation(fields: [businessId], references: [id])
  branch      Branch       @relation(fields: [branchId], references: [id])

  @@index([businessId])
  @@index([createdAt])
}

model Liability {
  id           String        @id 
  businessId   String
  branchId     String?
  title        String
  type         LiabilityType
  principalAmount       Float
  interestRate Float?         @default(0)
  startDate    DateTime
  dueDate      DateTime?
  lender       String?
  outstandingAmount   Decimal
  description  String?
  isOpening    Boolean  @default(true)
  status       LiabilityStatus
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  business     Business     @relation(fields: [businessId], references: [id])
  branch       Branch?       @relation(fields: [branchId], references: [id])

  liability    LiabilityPayment[]
}
model LiabilityPayment {
  id           String     @id  
  liabilityId  String
  liabilities  Liability        @relation(fields: [liabilityId], references: [id])
  amount       Float?
  paymentDate  DateTime?
}

model Asset {
  id               String    @id 
  businessId       String
  branchId         String
  name             String
  purchaseCost     Float
  purchaseDate     DateTime?
  assetType        AssetType
  totalCost        Decimal?
  currentValue     Decimal?
  quantity         Int
  isOpeninig       Boolean    @default(true)
  condition        String?
  supplier         String?
  usefulLifeMonths Int
  salvageValue     Decimal?
  accumulatedDepreciation   Float?
  disposedAt       DateTime?
  disposalAmount   Decimal?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  business         Business  @relation(fields: [businessId], references: [id])
  branch           Branch?   @relation(fields: [branchId], references: [id])
}


model Expense {
  id            String        @id 
  businessId    String
  branchId      String?
  categoryId    String?
  amount        Decimal
  paymentMethod PaymentMethod @default(CASH)
  reference     String?
  supplier      String?
  status        ExpenseStatus @default(APPROVED)
  description   String?
  date          DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  business      Business      @relation(fields: [businessId], references: [id])
  branch        Branch?        @relation(fields: [branchId], references: [id])
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id])

  @@index([businessId])
  @@index([categoryId])
}

model CapitalExpenditure {
  id            String   @id
  type          String
  amount        Decimal
  referenceType String
  referenceId   String
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

}

model Loan {
  id          String                 @id 
  businessId  String
  principal   Decimal?
  amount      Decimal
  interestRate Decimal                @default(0)
  dueDate     DateTime?
  lender      String?
  description String?
  createdById String?
  
  business    Business               @relation(fields: [businessId], references: [id])
  repayments  LoanRepayment[]
}

model LoanRepayment {
  id          String                 @id 
  loanId      String
  amount      Decimal
  date        DateTime               @default(now())

  loan        Loan                   @relation(fields: [loanId], references: [id])
}

model Employee {
  id          String    @id 
  businessId String
  name        String
  position    String
  salary      Decimal
  salaryType  String
  hiredAt     DateTime  @default(now())
  createdAt   DateTime  @default(now())

  business    Business  @relation(fields: [businessId], references: [id])
  salaryAccruals SalaryAccrual[]
}

model SalaryAccrual {
  id          String    @id 
  employeeId  String
  amount      Decimal
  month       Int
  year        Int
  createdAt   DateTime  @default(now())

  employee    Employee  @relation(fields: [employeeId], references: [id])
}

model  ExpenseCategory {
  id          String    @id 
  businessId  String
  name        String 
  createdAt   DateTime  @default(now())
  business    Business  @relation(fields: [businessId], references: [id])

  expenses    Expense[]

  @@unique([name, businessId])
}

model Alert {
  id            String   @id 
  businessId    String
  branchId      String   // null = global alert
  type          AlertType
  severity      AlertSeverity
  title         String
  message       String
  isResolved    Boolean   @default(false)
  isRead        Boolean   @default(false)
  metadata      Json?
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  business Business @relation(fields: [businessId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])

  @@index([branchId, isResolved])
  @@index([businessId, isResolved])
  @@index([type])
  @@unique([branchId, type, isResolved, metadata])
}
