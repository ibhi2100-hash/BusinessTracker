generator client {
  provider = "prisma-client"
  output   = "generated"
}

datasource db {
  provider = "postgresql"
}

/////**** ENUMS ****/////

enum Mode {
  OPENING
  LIVE
}

enum Scope {
  GLOBAL
  BUSINESS
  BRANCH
}

enum Role {
  ADMIN
  STAFF
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum Account {
  CASH
  BANK
  INVENTORY
  COGS
  REVENUE
  EXPENSE
  LIABILITIES
  OWNER_CAPITAL
  OWNER_DRAWINGS
  FIXED_ASSETS
  INTER_BRANCH
}

enum AlertType {
  LOW_STOCK
  SUBSCRIPTION
  LIABILITY_DUE
  CASH_VARIANCE
  SYSTEM
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum BusinessStatus {
  ONBOARDING
  ACTIVE
  SUSPENDED
}

enum SyncEventStatus {
  PENDING
  SYNCED
  FAILED
  DEAD
}

/////**** MODELS ****/////

model Business {
  id          String @id

  name        String

  userId      String?
  address     String?

  isOnboarding        Boolean @default(true)
  onboardingCompleted Boolean @default(false)

  status      BusinessStatus @default(ONBOARDING)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  activatedAt DateTime?

  owner User? @relation("BusinessOwner", fields: [userId], references: [id])

  branches      Branch[]
  users         User[]
  products      Product[]
  inventories   Inventory[]
  snapshots     Snapshot[]
  alerts        Alert[]
  events        Event[]
  ledgerEntries LedgerEntry[]
  aggregates    Aggregate[]

  subscriptions BusinessSubscription[]

  @@index([userId])
}

model Branch {
  id         String

  businessId String

  name       String

  address    String?
  phone      String?

  isActive   Boolean @default(true)
  isDefault  Boolean @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  users         User[]
  products      Product[]
  inventories   Inventory[]
  snapshots     Snapshot[]
  alerts        Alert[]
  events        Event[]
  ledgerEntries LedgerEntry[]

  @@id([id, businessId])

  @@unique([businessId, name])

  @@index([businessId])
}

model User {
  id String @id @default(uuid())

  businessId String?

  branchId         String?
  branchBusinessId String?

  name     String
  email    String @unique
  password String
  googleId String? @unique

  role Role @default(STAFF)

  isActive Boolean @default(true)

  onboardingCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  branch Branch? @relation(fields: [branchId, branchBusinessId],references: [id, businessId],onDelete: SetNull)

  ownedBusinesses Business[] @relation("BusinessOwner")

  passwordResetTokens PasswordResetToken[]

  events Event[]
  sessions   Session[]

  @@index([businessId])

  @@index([branchId, branchBusinessId])
}

model Session {
  id String @id @default(uuid())

  userId String

  refreshToken String @unique
  deviceId String?
  deviceName  String?
  ipAddress String?
  userAgent String?

  lastUsedAt  DateTime  @default(now())

  expiresAt DateTime

  createdAt DateTime @default(now())

  revokedAt  DateTime?

  user User @relation(fields: [userId],references: [id],onDelete: Cascade)

  @@index([userId])

  @@index([expiresAt])
}

model PasswordResetToken {
  id String @id

  userId String

  token String @unique

  expiresAt DateTime

  used Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId],references: [id],onDelete: Cascade)

  @@index([userId])

  @@index([expiresAt])
}

model SubscriptionPlan {
  id String @id

  name String

  price Decimal @db.Decimal(18, 6)

  billingCycle String

  maxUsers   Int
  maxBranch  Int
  maxProduct Int
  maxStaff   Int

  features Json

  createdAt DateTime @default(now())

  subscriptions BusinessSubscription[]
}

model BusinessSubscription {
  id String @id

  businessId String @unique

  subscriptionId String

  startedAt DateTime @default(now())

  expiresAt DateTime

  trialEndDate DateTime?

  status String @default("ACTIVE")

  business Business @relation(fields: [businessId],references: [id],onDelete: Cascade)

  subscription SubscriptionPlan @relation(fields: [subscriptionId],references: [id])

  @@index([subscriptionId])
}

model Product {
  id String

  businessId String

  branchId         String?
  branchBusinessId String?

  sku     String?
  barcode String?

  name String

  imageUrl   String?
  description String?

  category String?

  costPrice Decimal @db.Decimal(18, 6)

  price Decimal @db.Decimal(18, 6)

  reorderLevel Decimal? @db.Decimal(18, 6)

  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @default(now()) @updatedAt

  deletedAt DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  branch Branch? @relation(fields: [branchId, branchBusinessId], references: [id, businessId], onDelete: Restrict)

  inventories Inventory[]

  @@id([id, businessId])

  @@unique([businessId, sku])

  @@unique([businessId, barcode])

  @@index([businessId])

  @@index([branchId, branchBusinessId])

  @@index([name])

  @@index([category])
}
model Aggregate {
  id    String  @id
  aggregateId   String
  aggregateType   String
  businessId      String?
  branchId        String?
  version       Int
  lastEventId   String?
  lastLogicClock    Decimal?
  lastGlobalPosition    BigInt?
  lastSnaphotVersion     Decimal?
  createdAt               DateTime
  updatedAt                 DateTime?

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

}

model Inventory {
  id String @id

  businessId String

  branchId         String
  branchBusinessId String

  productId String

  quantity Decimal @db.Decimal(18, 6)

  costPrice Decimal @db.Decimal(18, 6)

  createdAt DateTime @default(now())

  updatedAt DateTime @default(now()) @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  branch Branch @relation(fields: [branchId, branchBusinessId], references: [id, businessId], onDelete: Cascade)

  product Product @relation(fields: [productId, businessId], references: [id, businessId], onDelete: Restrict)

  @@unique([businessId, branchId, productId])

  @@index([businessId])

  @@index([branchId, branchBusinessId])

  @@index([productId])
}

model ProcessedSyncEvent {
  id String @id

  eventType String

  businessId String?

  branchId         String?
  branchBusinessId String?

  userId String?

  version BigInt?

  status SyncEventStatus

  processedAt DateTime @default(now())

  error String?

  createdAt DateTime @default(now())

  updatedAt DateTime @default(now()) @updatedAt

  @@index([businessId])

  @@index([branchId, branchBusinessId])
}

model Event {
  id String   @id

  businessId String?

  branchId         String?
  branchBusinessId String?

  aggregateId   String
  aggregateType String
  aggregateVersion Int

  globalPosition BigInt @default(autoincrement())

  type String

  payload Json

  mode Mode

  scope Scope

  logicClock BigInt

  deviceId String

  userId String?


  status SyncEventStatus

  synced Boolean @default(false)
  isCreationEvent Boolean @default(false)
  causationId  String?
  correlationId String?

  createdAt DateTime @default(now())

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  branch Branch? @relation(fields: [branchId, branchBusinessId], references: [id, businessId], onDelete: SetNull)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  ledgerEntries LedgerEntry[]

  @@unique([aggregateType, aggregateId, aggregateVersion])

  @@index([businessId])

  @@index([branchId, branchBusinessId])

  @@index([aggregateType, aggregateId])

  @@index([deviceId, logicClock])

  @@index([createdAt])

  @@index([userId])
}
model DeviceClock {
  deviceId   String @id
  lastClock  Int
  updatedAt  DateTime @updatedAt
}
model LedgerEntry {
  id String @id @default(uuid())

  businessId String

  branchId         String
  branchBusinessId String

  eventId String

  type String

  account Account

  direction LedgerDirection

  amount Decimal @db.Decimal(18, 6)


  index Int

  createdAt DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  branch Branch @relation(fields: [branchId, branchBusinessId], references: [id, businessId], onDelete: Restrict)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, index])

  @@index([businessId, branchId])

  @@index([account])

  @@index([createdAt])
}

model Snapshot {
  id String @id

  businessId String

  branchId         String?
  branchBusinessId String?

  aggregateId String?
  aggregateType String?

  account String?

  balance Decimal? @db.Decimal(18, 6)

  version Int

  snapshotType String

  scope String

  data Json

  lastGlobalPosition BigInt
  snapshotKey String   @unique

  compressed Boolean @default(false)

  checksum String?
  eventCount Int  @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @default(now()) @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  branch Branch? @relation(fields: [branchId, branchBusinessId], references: [id, businessId], onDelete: SetNull)

  
  @@index([businessId, version])

  @@index([branchId, branchBusinessId, version])

  @@index([snapshotType])
}

model Alert {
  id String @id

  businessId String

  branchId         String?
  branchBusinessId String?

  type AlertType

  severity AlertSeverity

  title String

  message String

  metadata Json?

  isResolved Boolean @default(false)

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  resolvedAt DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  branch Branch? @relation(fields: [branchId, branchBusinessId], references: [id, businessId], onDelete: SetNull)

  @@index([businessId, isResolved])

  @@index([branchId, branchBusinessId, isResolved])

  @@index([type])

  @@index([severity])

  @@index([createdAt])
}